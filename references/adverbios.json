    {
      "titre": "Adverbes de lieu",
      "type": "regles",
      "items": [
        {
          "regle": "aquí / acá = ici (près du locuteur)",
          "detail": "Aquí estoy. Ven acá. acá est plus courant en Amérique latine."
        },
        {
          "regle": "ahí = là (près de l'interlocuteur)",
          "detail": "Ahí está tu libro. Correspond au démonstratif ese."
        },
        {
          "regle": "allí / allá = là-bas (loin des deux)",
          "detail": "Allí vive mi abuela. allá est plus vague/lointain. Correspond à aquel."
        },
        {
          "regle": "Système à 3 degrés (comme les démonstratifs)",
          "detail": "aquí/acá (este) — ahí (ese) — allí/allá (aquel)"
        },
        {
          "regle": "arriba/abajo = en haut/en bas",
          "detail": "Vive arriba. El gato está abajo."
        },
        {
          "regle": "dentro/fuera = dedans/dehors",
          "detail": "Está dentro de la caja. Sal fuera."
        },
        {
          "regle": "delante/detrás = devant/derrière",
          "detail": "Delante de la casa. Detrás de ti."
        },
        {
          "regle": "encima/debajo = dessus/dessous",
          "detail": "Encima de la mesa. Debajo del puente."
        }
      ]
    },
    {
      "titre": "Lieu — exemples",
