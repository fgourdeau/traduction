          "es": "Allí se ve el mar.",
          "fr": "Là-bas on voit la mer."
        },
        {
          "es": "El perro está debajo de la mesa.",
          "fr": "Le chien est sous la table."
        },
        {
          "es": "Vive cerca del centro.",
          "fr": "Il habite près du centre."
        }
      ]
    },
    {
      "titre": "Adverbes de temps",
      "type": "regles",
      "items": [
        {
          "regle": "hoy / ayer / mañana",
          "detail": "Aujourd'hui / hier / demain. Ayer fui al cine. Mañana salimos."
        },
        {
          "regle": "ahora = maintenant",
          "detail": "Ahora no puedo. Ahora mismo = tout de suite."
        },
        {
          "regle": "ya = déjà / maintenant",
          "detail": "Ya he comido (déjà). Ya voy (j'arrive). Ya no = ne… plus."
        },
        {
          "regle": "todavía / aún = encore",
          "detail": "Todavía está lloviendo. Aún no ha llegado."
        },
        {
          "regle": "siempre / nunca / jamás",
          "detail": "Toujours / jamais. Nunca et jamás sont interchangeables. Nunca jamás = emphase."
        },
        {
          "regle": "antes / después = avant / après",
          "detail": "Antes de comer. Después de las tres."
        },
        {
          "regle": "luego / entonces = ensuite / alors",
          "detail": "Primero como, luego descanso. Entonces se fue."
        },
        {
          "regle": "pronto / tarde = tôt-bientôt / tard",
          "detail": "Llegó pronto. Es demasiado tarde."
        },
        {
          "regle": "a veces / a menudo = parfois / souvent",
          "detail": "Locutions adverbiales très courantes."
        }
      ]
    },
    {
      "titre": "Temps — exemples",
      "type": "exemples",
      "items": [
        {
          "es": "Ya no vivo allí.",
          "fr": "Je n'habite plus là-bas. (ya no = ne… plus)"
        },
        {
          "es": "Todavía no ha llegado.",
          "fr": "Il n'est pas encore arrivé."
        },
        {
          "es": "Siempre dice lo mismo.",
          "fr": "Il dit toujours la même chose."
        },
        {
          "es": "Nunca he visto nada igual.",
          "fr": "Je n'ai jamais rien vu de pareil."
        },
        {
          "es": "Antes era diferente.",
          "fr": "Avant c'était différent."
        }
      ]
    },
    {
      "titre": "Adverbes en -mente (manière)",
      "type": "regles",
      "items": [
        {
          "regle": "Féminin de l'adjectif + -mente",
          "detail": "rápido → rápida → rápidamente. lento → lenta → lentamente."
        },
        {
          "regle": "Adjectif invariable en genre → directement + -mente",
          "detail": "fácil → fácilmente. frecuente → frecuentemente."
        },
        {
          "regle": "L'accent de l'adjectif est conservé",
          "detail": "rápida → rápidamente (accent sur á conservé)."
        },
        {
          "regle": "Deux adverbes en -mente : seul le dernier garde -mente",
          "detail": "Clara y concisamente (pas *claramente y concisamente)."
        },
        {
          "regle": "Alternative sans -mente : con + nom",
          "detail": "con cuidado (= cuidadosamente), con frecuencia (= frecuentemente). Souvent préféré."
        }
      ]
    },
