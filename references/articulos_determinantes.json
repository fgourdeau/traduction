    {
      "titre": "Possessifs — exemples",
      "type": "exemples",
      "items": [
        {"es": "Mi casa es tu casa.", "fr": "Ma maison est ta maison."},
        {"es": "Un amigo mío vive aquí.", "fr": "Un de mes amis vit ici."},
        {"es": "¿Es suyo este libro?", "fr": "Ce livre est à lui/elle/vous ?"},
        {"es": "Nuestros hijos están en la escuela.", "fr": "Nos enfants sont à l'école."}
      ]
    },
    {
      "titre": "Ambiguïté de su/sus/suyo",
      "type": "regles",
      "items": [
        {"regle": "su peut être = de él, de ella, de usted, de ellos, de ustedes", "detail": "Contexte seul ne suffit pas toujours → préciser : el libro de él, el libro de ella."},
        {"regle": "Forme longue aussi ambiguë", "detail": "Es suyo = c'est le sien/le vôtre → un amigo de él pour clarifier."}
      ]
    },
