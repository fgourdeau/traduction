    {
      "titre": "Démonstratifs — repères spatiaux",
      "type": "regles",
      "items": [
        {"regle": "este/esta → aquí/acá", "detail": "Proche du locuteur. Este libro (ce livre-ci, que je tiens)."},
        {"regle": "ese/esa → ahí", "detail": "Proche de l'interlocuteur. Ese libro (ce livre-là, près de toi)."},
        {"regle": "aquel/aquella → allí/allá", "detail": "Loin des deux. Aquel edificio (ce bâtiment là-bas)."},
        {"regle": "Neutres (esto, eso, aquello)", "detail": "Désignent une idée, une situation, jamais un nom précis. Eso es importante."}
      ]
    },
    {
      "titre": "Démonstratifs — exemples",
      "type": "exemples",
      "items": [
        {"es": "Este café está frío.", "fr": "Ce café(-ci) est froid."},
        {"es": "¿Qué es eso?", "fr": "Qu'est-ce que c'est (que ça) ?"},
        {"es": "Aquellos días fueron difíciles.", "fr": "Ces jours-là furent difficiles."}
      ]
    },
