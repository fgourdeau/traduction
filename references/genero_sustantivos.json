    {
      "titre": "El + nom féminin commençant par a-/ha- tonique",
      "type": "regles",
      "items": [
        {
          "regle": "el agua, el alma, el arma, el águila, el hambre, el hacha",
          "detail": "L'article el est utilisé au singulier pour éviter le choc sonore la a-. Le nom RESTE féminin."
        },
        {
          "regle": "Adjectifs au féminin",
          "detail": "el agua fría (pas *frío), el arma blanca, el alma pura."
        },
        {
          "regle": "Pluriel → retour à las",
          "detail": "las aguas, las almas, las armas, las águilas."
        },
        {
          "regle": "Démonstratifs et indéfinis aussi touchés",
          "detail": "esta agua (pas *este agua), mucha hambre (pas *mucho hambre). Seul l'article el est concerné."
        },
        {
          "regle": "Ne s'applique PAS si a- n'est pas tonique",
          "detail": "la abeja (l'abeille), la amiga (l'amie) — accent sur une autre syllabe."
        }
      ]
