    {
      "titre": "Comment deviner le genre — méthode rapide",
      "type": "regles",
      "items": [
        {
          "regle": "1. Regarder la terminaison",
          "detail": "-o → masc., -a → fém., -ción/-dad/-tud/-umbre/-ez → fém., -or/-aje/-ma grec → masc."
        },
        {
          "regle": "2. Vérifier les exceptions connues",
          "detail": "la mano, el día, el mapa, la foto, la moto, el problema, el agua (fém. avec el)."
        },
        {
          "regle": "3. En cas de doute : chercher l'article",
          "detail": "Apprendre el/la avec le nom, pas le nom seul. C'est la méthode la plus fiable."
        },
        {
          "regle": "4. Mot en -e ou -consonne ? Pas de règle fiable",
          "detail": "el coche, la noche, el árbol, la flor. Il faut mémoriser."
        }
