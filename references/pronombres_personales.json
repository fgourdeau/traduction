    {
      "titre": "Sujet : souvent omis",
      "type": "texte",
      "contenu": "En espagnol, le pronom sujet est généralement omis car la conjugaison identifie la personne. On l'utilise pour insister ou désambiguïser."
    },
    {
      "titre": "Sujet — exemples",
      "type": "exemples",
      "items": [
        {
          "es": "Hablo español.",
          "fr": "Je parle espagnol. (yo omis)"
        },
        {
          "es": "Yo hablo, tú escuchas.",
          "fr": "Moi je parle, toi tu écoutes. (insistance)"
        },
        {
          "es": "Ella vive aquí.",
          "fr": "Elle vit ici. (désambiguïsation)"
        }
      ]
    },
    {
      "titre": "COD vs COI",
      "type": "regles",
      "items": [
        {
          "regle": "COD (lo/la/los/las)",
          "detail": "Répond à « quoi ? qui ? » — Lo veo = Je le vois"
        },
        {
          "regle": "COI (le/les)",
          "detail": "Répond à « à qui ? » — Le hablo = Je lui parle"
        },
        {
          "regle": "se remplace le/les",
          "detail": "Devant lo/la/los/las : le lo → se lo. Se lo doy = Je le lui donne"
        }
      ]
    },
