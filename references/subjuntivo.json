    {
      "titre": "Subjonctif imparfait — formation",
      "type": "regles",
      "items": [
        {
          "regle": "Base = ellos du prétérit",
          "detail": "hablaron → habla-ra, comieron → comie-ra, dijeron → dije-ra, fueron → fue-ra."
        },
        {
          "regle": "Retirer -ron, ajouter -ra/-ras/-ra/-ramos/-rais/-ran",
          "detail": "tuvieron → tuvie- → tuviera, pudieron → pudie- → pudiera."
        },
        {
          "regle": "Forme en -se existe aussi",
          "detail": "hablase = hablara. Les deux sont correctes. -ra est plus fréquente en conversation."
        },
        {
          "regle": "Tous les irréguliers du prétérit → irréguliers ici",
          "detail": "ser/ir → fuera, tener → tuviera, hacer → hiciera, decir → dijera."
        }
      ]
