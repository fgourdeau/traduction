    {
      "titre": "Déclencheurs du subjonctif — les grandes catégories",
      "type": "regles",
      "items": [
        {
          "regle": "Souhait / volonté (querer que, esperar que, pedir que)",
          "detail": "Quiero que vengas. Espero que estés bien."
        },
        {
          "regle": "Émotion (alegrarse de que, temer que, sorprender que)",
          "detail": "Me alegro de que estés aquí. Es triste que se vaya."
        },
        {
          "regle": "Doute / négation (dudar que, no creer que)",
          "detail": "Dudo que venga. No creo que sea verdad."
        },
        {
          "regle": "Ordre indirect / conseil (decir que, recomendar que)",
          "detail": "Te digo que lo hagas. Recomiendo que estudies."
        },
        {
          "regle": "Jugement impersonnel (es necesario que, es posible que)",
          "detail": "Es importante que sepas. Es posible que llueva."
        },
        {
          "regle": "But (para que, a fin de que)",
          "detail": "Te lo digo para que lo sepas."
        },
        {
          "regle": "Temps futur (cuando, hasta que, antes de que)",
          "detail": "Cuando llegues, llámame. Antes de que se vaya."
        },
        {
          "regle": "Concession (aunque + doute)",
          "detail": "Aunque llueva, iré. (même s'il pleut — incertain)"
        }
      ]
    },
    {
      "titre": "Indicatif vs Subjonctif — paires contrastées",
      "type": "exemples",
      "items": [
        {
          "es": "Creo que es verdad. (indicatif)",
          "fr": "Je crois que c'est vrai. (certitude → indicatif)"
        },
        {
          "es": "No creo que sea verdad. (subjonctif)",
          "fr": "Je ne crois pas que ce soit vrai. (doute → subjonctif)"
        },
        {
          "es": "Cuando llega, come. (indicatif)",
          "fr": "Quand il arrive, il mange. (habitude → indicatif)"
        },
        {
          "es": "Cuando llegue, comeremos. (subjonctif)",
          "fr": "Quand il arrivera, nous mangerons. (futur → subjonctif)"
        },
        {
          "es": "Aunque está enfermo, trabaja. (indicatif)",
          "fr": "Bien qu'il soit malade (fait), il travaille."
        },
        {
          "es": "Aunque esté enfermo, trabajará. (subjonctif)",
          "fr": "Même s'il est malade (hypothèse), il travaillera."
        }
      ]
    },
